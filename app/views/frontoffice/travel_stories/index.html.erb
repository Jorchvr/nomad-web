<% content_for :title, "Travel Stories — World Nomad Web" %>

<!-- Hero -->
<div class="py-5 text-center text-white" style="background:linear-gradient(135deg,#1a2e20 0%,#3d7a55 100%);">
  <div class="container">
    <i class="bi bi-map fs-1 mb-3 d-block" style="color:#86c99a;"></i>
    <h1 class="fw-bold mb-2" style="font-family:'Lora',serif;">Travel Stories</h1>
    <p class="lead mb-0 opacity-75">Real nomad experiences — clients, cities, and adventures from around the world.</p>
  </div>
</div>

<div class="container py-5">

  <!-- Filter bar -->
  <% if @countries.any? %>
    <div class="d-flex flex-wrap gap-2 mb-4 align-items-center">
      <span class="text-muted small fw-semibold me-1">Filter by country:</span>
      <%= link_to "All", frontoffice_travel_stories_path,
            class: "btn btn-sm #{params[:country].blank? ? 'btn-primary' : 'btn-outline-secondary'}" %>
      <% @countries.each do |country| %>
        <%= link_to country, frontoffice_travel_stories_path(country: country),
              class: "btn btn-sm #{params[:country] == country ? 'btn-primary' : 'btn-outline-secondary'}" %>
      <% end %>
    </div>
  <% end %>

  <% if @stories.empty? %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-map fs-1 d-block mb-3" style="color:#c4d4b8;"></i>
      <p>No stories yet. Be the first to share your nomad experience!</p>
    </div>
  <% else %>
    <div class="row g-4">
      <% @stories.each do |story| %>
        <div class="col-md-6 col-xl-4">
          <%= link_to frontoffice_travel_story_path(story), class: "text-decoration-none" do %>
            <div class="card h-100 overflow-hidden story-card" style="transition:transform .2s,box-shadow .2s;cursor:pointer;">

              <!-- Cover image -->
              <div style="height:220px;background:#e8f0e2;overflow:hidden;">
                <% if story.photos.attached? %>
                  <%= image_tag story.photos.first,
                        style: "width:100%;height:100%;object-fit:cover;transition:transform .35s;",
                        class: "story-cover-img",
                        alt: story.title %>
                <% else %>
                  <div class="d-flex align-items-center justify-content-center h-100">
                    <i class="bi bi-image fs-1" style="color:#c4d4b8;"></i>
                  </div>
                <% end %>
              </div>

              <!-- Body -->
              <div class="p-4 d-flex flex-column flex-grow-1">
                <!-- Location + date -->
                <div class="d-flex align-items-center justify-content-between mb-2">
                  <span class="badge rounded-pill" style="background:#e8f0e2;color:#2d6044;font-size:.78rem;border:1px solid #c4d4b8;">
                    <i class="bi bi-geo-alt-fill me-1"></i><%= story.location %>
                  </span>
                  <span class="text-muted" style="font-size:.78rem;">
                    <%= story.visited_at.strftime("%b %Y") %>
                  </span>
                </div>

                <!-- Title -->
                <h5 class="fw-semibold mb-2" style="font-family:'Lora',serif;color:#1a2e20;
                    display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                  <%= story.title %>
                </h5>

                <!-- Excerpt -->
                <p class="text-muted small flex-grow-1 mb-3"
                   style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
                  <%= story.description %>
                </p>

                <!-- Author -->
                <div class="d-flex align-items-center gap-2 pt-3" style="border-top:1px solid #e8f0e2;">
                  <img src="<%= user_avatar_url(story.user, 40) %>"
                       alt="<%= story.user.name %>"
                       class="rounded-circle"
                       style="width:32px;height:32px;object-fit:cover;border:2px solid #c4d4b8;">
                  <div>
                    <p class="mb-0 fw-semibold" style="font-size:.82rem;color:#2d6044;"><%= story.user.name %></p>
                    <% if story.client_name.present? %>
                      <p class="mb-0 text-muted" style="font-size:.75rem;">
                        <i class="bi bi-briefcase me-1"></i><%= story.client_name %>
                      </p>
                    <% end %>
                  </div>
                  <span class="ms-auto text-muted" style="font-size:.78rem;">
                    <%= story.photos.size %> <i class="bi bi-images"></i>
                  </span>
                </div>
              </div>

            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<style>
  .story-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(45,96,68,.15) !important; }
  .story-card:hover .story-cover-img { transform: scale(1.04); }
</style>
