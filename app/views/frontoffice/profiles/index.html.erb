  "Egypt":["",[26.8206,30.8025]]
};

const nomads = <%= raw @map_profiles.map { |p|
  {
    id:         p.id,
    name:       p.name,
    profession: p.profession,
    city:       p.city.presence,
    country:    p.country,
    lat:        p.latitude,
    lng:        p.longitude,
    avatar:     user_avatar_url(p, 80),
    url:        frontoffice_profile_path(p)
  }
}.to_json %>;

const map = L.map('nomad-map', {
  center: [20, 10],
  zoom: 2,
  minZoom: 2,
  maxZoom: 10,
  zoomControl: true
});

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
  maxZoom: 18
}).addTo(map);

const usedCoords = {};

nomads.forEach(n => {
  let lat, lng;

  // 1. Use coordinates stored in DB (city-level precision)
  if (n.lat && n.lng) {
    lat = parseFloat(n.lat);
    lng = parseFloat(n.lng);
  } else {
    // 2. Fallback: country-level coordinates from COORDS
    const key = Object.keys(COORDS).find(k => k.toLowerCase() === (n.country||'').toLowerCase());
    if (!key) return;
    [lat, lng] = COORDS[key][1];
  }

  // Jitter if multiple nomads share the exact same point
  const ck = `${lat.toFixed(3)},${lng.toFixed(3)}`;
  usedCoords[ck] = (usedCoords[ck] || 0) + 1;
  if (usedCoords[ck] > 1) {
    const angle = (usedCoords[ck] - 1) * 137.5 * Math.PI / 180;
    const r = 0.15 * (usedCoords[ck] - 1);
    lat += r * Math.cos(angle);
    lng += r * Math.sin(angle);
  }

  const locationLabel = [n.city, n.country].filter(Boolean).join(', ');

  const icon = L.divIcon({
    html: `<div class="nomad-pin"><img src="${n.avatar}" alt="${n.name}" onerror="this.src='https://www.gravatar.com/avatar/?d=identicon'"/></div>`,
    className: '',
    iconSize: [48, 48],
    iconAnchor: [24, 24],
    popupAnchor: [0, -28]
  });

  const marker = L.marker([lat, lng], { icon }).addTo(map);
  marker.bindPopup(`
    <div class="map-popup">
      <img src="${n.avatar}" alt="${n.name}"/>
      <div>
        <div class="name">${n.name}</div>
        <div class="prof">${n.profession}</div>
        <div class="country"><i class="bi bi-geo-alt"></i> ${locationLabel}</div>
        <a href="${n.url}" style="margin-top:4px;display:inline-block;">View profile →</a>
      </div>
    </div>
  `, { maxWidth: 280 });
});
</script>
