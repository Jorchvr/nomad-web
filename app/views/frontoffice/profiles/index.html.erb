<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <style>
    #nomad-map { height: 480px; width: 100%; z-index: 1; }
    .nomad-pin {
      width: 48px; height: 48px;
      border-radius: 50%;
      border: 3px solid #3d7a55;
      overflow: hidden;
      box-shadow: 0 3px 10px rgba(0,0,0,.35);
      background: #f0ece3;
      cursor: pointer;
      transition: transform .15s;
    }
    .nomad-pin:hover { transform: scale(1.15); }
    .nomad-pin img { width: 100%; height: 100%; object-fit: cover; }
    .leaflet-popup-content-wrapper {
      border-radius: 12px;
      border: 1.5px solid #c4d4b8;
      box-shadow: 0 4px 16px rgba(45,96,68,.18);
    }
    .map-popup { display: flex; align-items: center; gap: 10px; min-width: 180px; }
    .map-popup img { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; border: 2px solid #c4d4b8; flex-shrink: 0; }
    .map-popup .name { font-weight: 600; font-size: .9rem; color: #1a2e20; }
    .map-popup .prof { font-size: .78rem; color: #5a7a6a; }
    .map-popup .country { font-size: .75rem; color: #8b6340; }
    .map-popup a { color: #3d7a55; font-size: .8rem; font-weight: 600; text-decoration: none; }
  </style>
<% end %>

<!-- Hero -->
<section class="hero text-white">
  <div class="container">
    <div class="row justify-content-center text-center mb-4">
      <div class="col-lg-7">
        <span class="wnw-logo wnw-logo-xl d-block mx-auto mb-4"></span>
        <h1 class="fw-bold display-5 mb-2" style="font-family:'Lora',serif;">Find your next collaborator</h1>
        <p class="mb-4 fs-5" style="color:rgba(255,255,255,.65);">Digital nomads from around the world, ready to connect.</p>
        <%= form_with url: frontoffice_profiles_path, method: :get, local: true do |f| %>
          <div class="input-group input-group-lg shadow-sm">
            <%= f.text_field :q, value: params[:q], placeholder: "Search by name, profession, country...",
                class: "form-control border-0", autocomplete: "off" %>
            <%= f.submit "Search", class: "btn btn-primary px-4" %>
          </div>
        <% end %>
      </div>
    </div>
    <% if @countries.any? %>
      <div class="d-flex flex-wrap gap-2 justify-content-center">
        <%= link_to "All", frontoffice_profiles_path(q: params[:q]),
              class: "btn btn-sm #{params[:country].blank? ? 'btn-primary' : 'btn-outline-light'}" %>
        <% @countries.each do |country| %>
          <%= link_to country, frontoffice_profiles_path(q: params[:q], country: country),
                class: "btn btn-sm #{params[:country] == country ? 'btn-primary' : 'btn-outline-light'}" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- Interactive map -->
<section style="background:#fff; border-bottom: 2px solid #c4d4b8;">
  <div id="nomad-map"></div>
</section>

<!-- Nomad grid -->
<div class="container py-5">
  <% if @profiles.any? %>
    <h5 class="fw-semibold mb-4" style="color:#2a3a2e;">
      <i class="bi bi-people-fill me-2" style="color:#3d7a55;"></i>
      <%= @profiles.count %> nomad<%= @profiles.count == 1 ? '' : 's' %>
      <% if params[:q].present? || params[:country].present? %>
        <span class="fw-normal text-muted fs-6"> found</span>
      <% end %>
    </h5>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
      <% @profiles.each do |profile| %>
        <div class="col">
          <%= link_to frontoffice_profile_path(profile), class: "text-decoration-none" do %>
            <div class="card nomad-card h-100 p-3">
              <div class="d-flex align-items-center gap-3 mb-3">
                <img src="<%= user_avatar_url(profile, 80) %>" alt="<%= profile.name %>"
                     class="avatar-circle flex-shrink-0">
                <div class="overflow-hidden">
                  <div class="fw-semibold text-dark text-truncate"><%= profile.name %></div>
                  <div class="text-muted small text-truncate"><%= profile.profession %></div>
                </div>
              </div>
              <span class="badge badge-country mb-2 align-self-start">
                <i class="bi bi-geo-alt me-1"></i>
                <%= [profile.city, profile.country].compact.join(', ') %>
              </span>
              <% if profile.bio.present? %>
                <p class="text-muted small mb-0" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
                  <%= profile.bio %>
                </p>
              <% end %>
              <div class="mt-auto pt-3 d-flex flex-wrap gap-2">
                <% if profile.whatsapp_url %>
                  <span class="badge bg-success"><i class="bi bi-whatsapp me-1"></i>WhatsApp</span>
                <% end %>
                <span class="badge bg-light text-dark border"><i class="bi bi-envelope me-1"></i>Email</span>
                <% if profile.profile_links.any? %>
                  <span class="badge" style="background:#e8f5ee;color:#2d6044;border:1px solid #b2d8c0;">
                    <i class="bi bi-link-45deg me-1"></i><%= profile.profile_links.count %> link<%= profile.profile_links.count > 1 ? 's' : '' %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <i class="bi bi-search display-3 text-muted"></i>
      <h4 class="mt-3 text-muted">No nomads found</h4>
      <p class="text-muted">Try a different search term or
        <%= link_to "view all profiles", frontoffice_profiles_path %>.
      </p>
    </div>
  <% end %>
</div>

