<div class="container py-5">
  <%= link_to frontoffice_profiles_path, class: "text-decoration-none text-muted small mb-4 d-inline-flex align-items-center gap-1" do %>
    <i class="bi bi-arrow-left"></i> Back to directory
  <% end %>

  <div class="row g-4 mt-1">
    <!-- Left column: main info -->
    <div class="col-lg-4">

      <!-- Identity card -->
      <div class="card p-4 text-center mb-4">
        <img src="<%= user_avatar_url(@profile, 180) %>" alt="<%= @profile.name %>"
             class="rounded-circle mx-auto mb-3 d-block"
             style="width:120px;height:120px;object-fit:cover;border:4px solid #c4d4b8;">
        <h3 class="fw-bold mb-1" style="font-family:'Lora',serif;">
          <%= @profile.name %>
          <% if @profile.verified? %>
            <i class="bi bi-patch-check-fill" style="color:#3d7a55;font-size:1.1rem;" title="Verified member"></i>
          <% end %>
        </h3>
        <p class="text-muted mb-3"><%= @profile.profession %></p>
        <span class="badge badge-country fs-6 d-inline-flex align-items-center gap-1 mx-auto mb-3">
          <i class="bi bi-geo-alt-fill"></i>
          <%= [@profile.city, @profile.country].compact.join(', ') %>
        </span>
        <div class="text-muted small">
          <i class="bi bi-calendar3 me-1"></i>
          Member since <%= @profile.created_at.strftime("%B %Y") %>
        </div>
      </div>

      <!-- Contact -->
      <% unless current_user && current_user.id == @profile.id %>
        <div class="card p-4 mb-4">
          <h6 class="fw-semibold mb-3" style="color:#2d6044;">
            <i class="bi bi-chat-dots-fill me-2"></i>Contact
          </h6>
          <div class="d-grid gap-2">
            <% if current_user %>
              <%= link_to backoffice_message_conversation_path(@profile.id),
                    class: "btn btn-primary d-flex align-items-center justify-content-center gap-2 fw-semibold" do %>
                <i class="bi bi-chat-fill fs-5"></i>
                <span>Send message</span>
              <% end %>
            <% else %>
              <%= link_to backoffice_login_path,
                    class: "btn btn-primary d-flex align-items-center justify-content-center gap-2 fw-semibold" do %>
                <i class="bi bi-chat-fill fs-5"></i>
                <span>Sign in to message</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Profile links -->
      <% if @profile.profile_links.any? %>
        <div class="card p-4 mb-4">
          <h6 class="fw-semibold mb-3" style="color:#2d6044;">
            <i class="bi bi-link-45deg me-2"></i>Links
          </h6>
          <div class="d-grid gap-2">
            <% @profile.profile_links.each do |link| %>
              <%= link_to link.url, target: "_blank", rel: "noopener noreferrer",
                    class: "btn btn-outline-primary d-flex align-items-center gap-2 text-start" do %>
                <i class="bi bi-box-arrow-up-right"></i>
                <span class="text-truncate"><%= link.label %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>

    <!-- Right column: bio, photos -->
    <div class="col-lg-8">

      <!-- Bio -->
      <% if @profile.bio.present? %>
        <div class="card p-4 mb-4">
          <h5 class="fw-semibold mb-3" style="font-family:'Lora',serif;color:#1a2e20;">
            <i class="bi bi-person-lines-fill me-2" style="color:#3d7a55;"></i>About me
          </h5>
          <div class="text-secondary lh-lg" style="font-size:1.02rem;">
            <%= simple_format(@profile.bio) %>
          </div>
        </div>
      <% end %>

      <!-- Portfolio entry -->
      <% if @profile.work_photos.any? %>
        <div class="card p-4 mb-4">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="fw-semibold mb-0" style="font-family:'Lora',serif;color:#1a2e20;">
              <i class="bi bi-images me-2" style="color:#3d7a55;"></i>Portfolio
            </h5>
            <span class="badge rounded-pill" style="background:#3d7a55;font-size:.82rem;">
              <%= @profile.work_photos.size %> <%= @profile.work_photos.size == 1 ? 'project' : 'projects' %>
            </span>
          </div>

          <!-- Preview strip: first 3 thumbnails -->
          <div class="row g-2 mb-3">
            <% @profile.work_photos.includes(image_attachment: :blob).order(created_at: :desc).first(3).each do |photo| %>
              <div class="col-4">
                <div class="rounded-3 overflow-hidden" style="aspect-ratio:1;border:1.5px solid #c4d4b8;background:#f5f0e8;">
                  <%= image_tag photo.image,
                        style: "width:100%;height:100%;object-fit:cover;",
                        alt: "" %>
                </div>
              </div>
            <% end %>
          </div>

          <%= link_to portfolio_frontoffice_profile_path(@profile),
                class: "btn w-100 d-flex align-items-center justify-content-center gap-2 fw-semibold",
                style: "background:#3d7a55;color:#fff;border:none;" do %>
            <i class="bi bi-grid-3x3-gap-fill"></i>
            View full portfolio
            <i class="bi bi-arrow-right"></i>
          <% end %>
        </div>
      <% end %>

      <!-- Additional info -->
      <div class="card p-4">
        <h5 class="fw-semibold mb-3" style="font-family:'Lora',serif;color:#1a2e20;">
          <i class="bi bi-info-circle me-2" style="color:#3d7a55;"></i>Information
        </h5>
        <dl class="row mb-0" style="font-size:.95rem;">
          <dt class="col-sm-4 text-muted fw-normal">Name</dt>
          <dd class="col-sm-8 fw-semibold"><%= @profile.name %></dd>

          <dt class="col-sm-4 text-muted fw-normal">Profession</dt>
          <dd class="col-sm-8"><%= @profile.profession %></dd>

          <% if @profile.city.present? %>
            <dt class="col-sm-4 text-muted fw-normal">City</dt>
            <dd class="col-sm-8">
              <i class="bi bi-building me-1" style="color:#3d7a55;"></i><%= @profile.city %>
            </dd>
          <% end %>
          <dt class="col-sm-4 text-muted fw-normal">Country</dt>
          <dd class="col-sm-8">
            <i class="bi bi-geo-alt me-1" style="color:#3d7a55;"></i><%= @profile.country %>
          </dd>

          <% if @profile.profile_links.any? %>
            <dt class="col-sm-4 text-muted fw-normal">Links</dt>
            <dd class="col-sm-8">
              <% @profile.profile_links.each do |link| %>
                <%= link_to link.label, link.url,
                      target: "_blank", rel: "noopener noreferrer",
                      class: "d-block text-decoration-none me-2",
                      style: "color:#3d7a55;" %>
              <% end %>
            </dd>
          <% end %>

          <dt class="col-sm-4 text-muted fw-normal">Member since</dt>
          <dd class="col-sm-8"><%= @profile.created_at.strftime("%B %-d, %Y") %></dd>
        </dl>
      </div>

    </div>
  </div>
</div>
