<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <title>World Nomad Web — Dashboard</title>
    <link rel="icon" href="/logo.png" type="image/png">
    <script>(function(){var t=localStorage.getItem('wnw-theme')||'light';document.documentElement.setAttribute('data-bs-theme',t);})();</script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%= yield :head %>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Lora:wght@500;600;700&family=Inter:wght@400;500;600&display=swap');
      :root {
        --wnw-primary:      #3d7a55;
        --wnw-primary-dark: #2d6044;
        --wnw-primary-light:#e8f5ee;
        --wnw-dark:         #1a2e20;
        --wnw-sidebar:      #1e3828;
        --wnw-bark:         #8b6340;
        --wnw-parchment:    #f5f0e8;
        --wnw-border:       #c4d4b8;
        --wnw-card-shadow:  rgba(45, 96, 68, .09);
      }
      body {
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
        background: var(--wnw-parchment);
        color: #2a3a2e;
      }
      /* ── Logo WNW ── */
      .wnw-logo {
        display: inline-block;
        flex-shrink: 0;
        border-radius: 50%;
        background: #f0ece3 url('/logo.png') 50% 44% / 210% no-repeat;
        box-shadow: 0 2px 10px rgba(0,0,0,.25);
      }
      .wnw-logo-sm { width: 40px;  height: 40px; }
      .wnw-logo-md { width: 68px;  height: 68px; }
      .wnw-logo-lg { width: 96px;  height: 96px; }
      .wnw-logo-xl { width: 130px; height: 130px; box-shadow: 0 6px 28px rgba(0,0,0,.35); }
      /* ── Sidebar ── */
      .sidebar {
        width: 242px;
        min-height: 100vh;
        background: var(--wnw-sidebar);
        position: fixed;
        top: 0; left: 0;
        display: flex;
        flex-direction: column;
        padding: 0;
        z-index: 100;
        border-right: 1px solid rgba(255,255,255,.05);
      }
      .sidebar-brand {
        padding: 14px 18px;
        border-bottom: 1px solid rgba(255,255,255,.08);
        color: #fff;
        font-family: 'Lora', serif;
        font-weight: 600;
        font-size: .92rem;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(0,0,0,.15);
      }
      .sidebar-brand .brand-name { color: #fff; }
      .sidebar-brand .brand-name span { color: #86c99a; }
      .sidebar-nav { padding: 10px 0; flex: 1; }
      .sidebar-nav a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 18px;
        color: #a8c4b0;
        text-decoration: none;
        font-size: .88rem;
        transition: all .15s;
        border-left: 3px solid transparent;
        margin: 1px 0;
      }
      .sidebar-nav a:hover {
        color: #fff;
        background: rgba(255,255,255,.06);
        border-left-color: rgba(134,201,154,.4);
      }
      .sidebar-nav a.active {
        color: #fff;
        background: rgba(61,122,85,.35);
        border-left-color: #86c99a;
      }
      .sidebar-nav a i { font-size: 1rem; width: 18px; }
      .sidebar-footer {
        padding: 14px 18px;
        border-top: 1px solid rgba(255,255,255,.08);
        background: rgba(0,0,0,.1);
      }
      /* ── Topbar ── */
      .main-content {
        margin-left: 242px;
        padding: 28px 32px;
        min-height: 100vh;
      }
      .topbar {
        background: #fffdf8;
        border-bottom: 2px solid var(--wnw-border);
        padding: 10px 32px;
        margin-left: 242px;
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      /* ── Cards ── */
      .card {
        border: 1.5px solid var(--wnw-border) !important;
        box-shadow: 0 2px 8px var(--wnw-card-shadow) !important;
        border-radius: 12px !important;
        background: #fff !important;
      }
      /* ── Buttons ── */
      .btn-primary { background: var(--wnw-primary); border-color: var(--wnw-primary); }
      .btn-primary:hover { background: var(--wnw-primary-dark); border-color: var(--wnw-primary-dark); }
      .btn-outline-primary { color: var(--wnw-primary); border-color: var(--wnw-primary); }
      .btn-outline-primary:hover { background: var(--wnw-primary); border-color: var(--wnw-primary); color: #fff; }
      .btn-outline-secondary { border-color: var(--wnw-border); color: #4a6555; }
      .btn-outline-secondary:hover { background: var(--wnw-border); color: #2a3a2e; }
      /* ── Badges ── */
      .badge-published { background: #d4edda; color: #2d6a4f; border: 1px solid #b2d8c0; }
      .badge-draft     { background: #fef3cd; color: #8b6340; border: 1px solid #e8d49e; }
      /* ── Inputs ── */
      .form-control:focus { border-color: var(--wnw-primary); box-shadow: 0 0 0 .2rem rgba(61,122,85,.18); }
      /* ── Auth ── */
      .auth-page { margin-left: 0 !important; }
      .auth-sidebar-hidden .sidebar { display: none; }
      /* ── Auth background ── */
      .auth-bg {
        background: linear-gradient(150deg, #1a2e20 0%, #2d5a3d 100%);
        min-height: 100vh;
      }
      /* ── Dark mode ── */
      [data-bs-theme="dark"] body { background: #0d1610; color: #c8e0c8; }
      [data-bs-theme="dark"] .card { background: #162018 !important; border-color: #253b2a !important; }
      [data-bs-theme="dark"] .topbar { background: #111c14; border-bottom-color: #253b2a; }
      [data-bs-theme="dark"] .form-control { background: #162018; border-color: #2a4030; color: #c8e0c8; }
      [data-bs-theme="dark"] .form-control::placeholder { color: #5a7a5a; }
      [data-bs-theme="dark"] .form-control:focus { background: #162018; border-color: #3d7a55; color: #c8e0c8; }
      [data-bs-theme="dark"] .btn-outline-secondary { border-color: #2a4030; color: #8ab08a; }
      [data-bs-theme="dark"] .btn-outline-secondary:hover { background: #253b2a; color: #c8e0c8; }
      [data-bs-theme="dark"] .text-muted { color: #6a9a6a !important; }
      [data-bs-theme="dark"] .alert-success { background: #1a3a1e; border-color: #2d6044; color: #86c99a; }
      [data-bs-theme="dark"] .alert-danger  { background: #2d1a1a; border-color: #6a3030; color: #e89898; }
      [data-bs-theme="dark"] .badge-published { background: #1a3a1e; color: #86c99a; border-color: #2d6044; }
      [data-bs-theme="dark"] .badge-draft { background: #2d2010; color: #c4a060; border-color: #5a4020; }
      [data-bs-theme="dark"] .form-check-input { background-color: #162018; border-color: #2a4030; }
      [data-bs-theme="dark"] .table { --bs-table-color: #c8e0c8; --bs-table-border-color: #253b2a; }
      [data-bs-theme="dark"] hr { border-color: #253b2a; }
      [data-bs-theme="dark"] .modal-content { background: #162018; border-color: #253b2a; }
      [data-bs-theme="dark"] .dropdown-menu { background: #162018; border-color: #253b2a; }
      [data-bs-theme="dark"] .dropdown-item:hover { background: #253b2a; }
    </style>
  </head>
  <body>
    <% if current_user %>
      <div class="sidebar">
        <%= link_to backoffice_root_path, class: "sidebar-brand" do %>
          <span class="wnw-logo wnw-logo-sm"></span>
          <span class="brand-name">World <span>Nomad</span> Web</span>
        <% end %>
        <nav class="sidebar-nav">
          <% unread = Message.unread_for(current_user).count %>
          <% if current_user.nomad? %>
            <%= link_to backoffice_root_path, class: "#{controller_name == 'dashboard' ? 'active' : ''}" do %>
              <i class="bi bi-speedometer2"></i> Dashboard
            <% end %>
            <%= link_to backoffice_profile_path, class: "#{controller_name == 'profiles' && action_name == 'show' ? 'active' : ''}" do %>
              <i class="bi bi-person-circle"></i> My Profile
            <% end %>
            <%= link_to edit_backoffice_profile_path, class: "#{controller_name == 'profiles' && action_name == 'edit' ? 'active' : ''}" do %>
              <i class="bi bi-pencil-square"></i> Edit Profile
            <% end %>
            <div class="sidebar-nav-divider" style="border-top:1px solid rgba(255,255,255,.05);margin:6px 0;"></div>
            <%= link_to backoffice_members_path, class: "#{controller_name == 'members' ? 'active' : ''}" do %>
              <i class="bi bi-globe2"></i> Nomads
            <% end %>
            <%= link_to backoffice_friendships_path, class: "#{controller_name == 'friendships' ? 'active' : ''}" do %>
              <i class="bi bi-people-fill"></i> Friends
              <% pending = current_user.pending_friend_requests.count %>
              <% if pending > 0 %>
                <span class="badge bg-warning text-dark ms-auto"><%= pending %></span>
              <% end %>
            <% end %>
            <%= link_to backoffice_messages_path, class: "#{controller_name == 'messages' ? 'active' : ''}" do %>
              <i class="bi bi-chat-dots-fill"></i> Messages
              <% if unread > 0 %>
                <span class="badge ms-auto" style="background:#3d7a55;"><%= unread %></span>
              <% end %>
            <% end %>
            <%= link_to backoffice_forums_path, class: "#{controller_name == 'forums' ? 'active' : ''}" do %>
              <i class="bi bi-chat-square-text"></i> Forums
            <% end %>
            <%= link_to backoffice_work_photos_path, class: "#{controller_name == 'work_photos' ? 'active' : ''}" do %>
              <i class="bi bi-images"></i> My Photos
            <% end %>
            <%= link_to backoffice_travel_stories_path, class: "#{controller_name == 'travel_stories' ? 'active' : ''}" do %>
              <i class="bi bi-map"></i> Travel Stories
            <% end %>
            <div class="sidebar-nav-divider" style="border-top:1px solid rgba(255,255,255,.05);margin:6px 0;"></div>
            <%= link_to root_path do %>
              <i class="bi bi-grid"></i> View Directory
            <% end %>
            <%= link_to backoffice_tutorial_path, class: "#{controller_name == 'dashboard' && action_name == 'tutorial' ? 'active' : ''}" do %>
              <i class="bi bi-question-circle"></i> How to use
            <% end %>
          <% else %>
            <%# Client sidebar — minimal %>
            <%= link_to backoffice_messages_path, class: "#{controller_name == 'messages' ? 'active' : ''}" do %>
              <i class="bi bi-chat-dots-fill"></i> Messages
              <% if unread > 0 %>
                <span class="badge ms-auto" style="background:#3d7a55;"><%= unread %></span>
              <% end %>
            <% end %>
            <div class="sidebar-nav-divider" style="border-top:1px solid rgba(255,255,255,.05);margin:6px 0;"></div>
            <%= link_to root_path do %>
              <i class="bi bi-search"></i> Browse Nomads
            <% end %>
            <%= link_to frontoffice_travel_stories_path do %>
              <i class="bi bi-map"></i> Travel Stories
            <% end %>
          <% end %>
        </nav>
        <div class="sidebar-footer">
          <div class="text-white-50 small mb-2 text-truncate">
            <i class="bi bi-person-fill me-1"></i><%= current_user.name %>
          </div>
          <%= button_to backoffice_logout_path, method: :delete, class: "btn btn-sm btn-outline-secondary w-100" do %>
            <i class="bi bi-box-arrow-left me-1"></i>Sign out
          <% end %>
        </div>
      </div>
    <% end %>

    <% if current_user %>
      <div class="topbar">
        <span class="text-muted small">
          <%= content_for?(:page_title) ? yield(:page_title) : "Dashboard" %>
        </span>
        <div class="d-flex align-items-center gap-2">
          <% if current_user.nomad? %>
            <% if current_user.published? %>
              <span class="badge badge-published"><i class="bi bi-check-circle me-1"></i>Profile published</span>
            <% else %>
              <span class="badge badge-draft"><i class="bi bi-eye-slash me-1"></i>Profile hidden</span>
            <% end %>
          <% else %>
            <span class="badge rounded-pill px-3"
                  style="background:#f5f0e8;color:#8b6340;border:1px solid #ddd0b8;font-size:.78rem;">
              <i class="bi bi-briefcase-fill me-1"></i>Client account
            </span>
          <% end %>
          <button id="theme-toggle" onclick="toggleTheme()"
                  class="btn btn-sm btn-outline-secondary"
                  title="Toggle dark mode"
                  style="width:36px;height:36px;padding:0;display:flex;align-items:center;justify-content:center;">
            <i class="bi" id="theme-icon"></i>
          </button>
        </div>
      </div>
    <% end %>

    <div class="<%= current_user ? 'main-content' : 'd-flex align-items-center justify-content-center auth-bg' %>">
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show">
          <i class="bi bi-check-circle me-2"></i><%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show">
          <i class="bi bi-exclamation-circle me-2"></i><%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      function applyThemeIcon(t) {
        const icon = document.getElementById("theme-icon");
        if (icon) icon.className = "bi bi-" + (t === "dark" ? "sun-fill" : "moon-fill");
      }
      function toggleTheme() {
        const cur  = document.documentElement.getAttribute("data-bs-theme");
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-bs-theme", next);
        localStorage.setItem("wnw-theme", next);
        applyThemeIcon(next);
      }
      applyThemeIcon(document.documentElement.getAttribute("data-bs-theme"));
    </script>
  </body>
</html>
