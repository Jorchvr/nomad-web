<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>World Nomad Web</title>
    <link rel="icon" href="/logo.png" type="image/png">
    <script>(function(){var t=localStorage.getItem('wnw-theme')||'light';document.documentElement.setAttribute('data-bs-theme',t);})();</script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%= yield :head %>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Lora:wght@500;600;700&family=Inter:wght@400;500;600&display=swap');
      :root {
        --wnw-primary:      #3d7a55;
        --wnw-primary-dark: #2d6044;
        --wnw-primary-light:#e8f5ee;
        --wnw-dark:         #1a2e20;
        --wnw-bark:         #8b6340;
        --wnw-parchment:    #f5f0e8;
        --wnw-border:       #c4d4b8;
        --wnw-card-shadow:  rgba(45, 96, 68, .10);
      }
      body {
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
        background: var(--wnw-parchment);
        color: #2a3a2e;
      }
      /* ── Logo WNW ── */
      .wnw-logo {
        display: inline-block;
        flex-shrink: 0;
        border-radius: 50%;
        background: #f0ece3 url('/logo.png') 50% 44% / 210% no-repeat;
        box-shadow: 0 3px 12px rgba(0,0,0,.22);
      }
      .wnw-logo-sm { width: 40px;  height: 40px; }
      .wnw-logo-md { width: 68px;  height: 68px; }
      .wnw-logo-lg { width: 96px;  height: 96px; }
      .wnw-logo-xl { width: 130px; height: 130px; box-shadow: 0 8px 32px rgba(0,0,0,.38); }
      /* ── Navbar ── */
      .navbar-brand { display: flex; align-items: center; gap: 10px; }
      .navbar-brand .brand-text { color: #fff; font-family: 'Lora', serif; font-size: 1.05rem; }
      .navbar-brand .brand-text span { color: #86c99a; }
      /* ── Buttons ── */
      .btn-primary { background: var(--wnw-primary); border-color: var(--wnw-primary); }
      .btn-primary:hover { background: var(--wnw-primary-dark); border-color: var(--wnw-primary-dark); }
      .btn-outline-primary { color: var(--wnw-primary); border-color: var(--wnw-primary); }
      .btn-outline-primary:hover { background: var(--wnw-primary); border-color: var(--wnw-primary); color: #fff; }
      .text-primary { color: var(--wnw-primary) !important; }
      /* ── Hero ── */
      .hero {
        background: linear-gradient(150deg, #1a2e20 0%, #2d5a3d 55%, #3d6b4a 100%);
        padding: 80px 0 64px;
        position: relative;
        overflow: hidden;
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      }
      /* ── Cards ── */
      .nomad-card {
        transition: transform .2s, box-shadow .2s, border-color .2s;
        border: 1.5px solid var(--wnw-border);
        box-shadow: 0 2px 8px var(--wnw-card-shadow);
        background: #fff;
        border-radius: 12px;
      }
      .nomad-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 28px rgba(45, 96, 68, .16);
        border-color: var(--wnw-primary);
      }
      .card {
        border: 1.5px solid var(--wnw-border) !important;
        box-shadow: 0 2px 8px var(--wnw-card-shadow) !important;
        border-radius: 12px !important;
        background: #fff;
      }
      /* ── Avatar ── */
      .avatar-circle {
        width: 72px; height: 72px;
        border-radius: 50%; object-fit: cover;
        border: 2px solid var(--wnw-border);
      }
      /* ── Badges ── */
      .badge-country {
        background: var(--wnw-primary-light);
        color: var(--wnw-primary-dark);
        border: 1px solid #b2d8c0;
        font-weight: 500;
        border-radius: 20px;
      }
      /* ── Footer ── */
      footer {
        background: var(--wnw-dark);
        border-top: 3px solid #2d5a3d;
      }
      /* ── Input focus ── */
      .form-control:focus { border-color: var(--wnw-primary); box-shadow: 0 0 0 .2rem rgba(61,122,85,.18); }
      /* ── Dark mode ── */
      [data-bs-theme="dark"] body { background: #0d1610; color: #c8e0c8; }
      [data-bs-theme="dark"] .card { background: #162018 !important; border-color: #253b2a !important; }
      [data-bs-theme="dark"] .nomad-card { background: #162018; border-color: #253b2a; }
      [data-bs-theme="dark"] .nomad-card:hover { border-color: var(--wnw-primary); }
      [data-bs-theme="dark"] nav.navbar { background: #0a1209 !important; border-bottom-color: #1a3020 !important; }
      [data-bs-theme="dark"] footer { background: #080f09 !important; }
      [data-bs-theme="dark"] .text-muted { color: #6a9a6a !important; }
      [data-bs-theme="dark"] .text-secondary { color: #6a9a6a !important; }
      [data-bs-theme="dark"] .badge-country { background: #1a3a20; color: #86c99a; border-color: #2d6044; }
      [data-bs-theme="dark"] .form-control { background: #162018; border-color: #2a4030; color: #c8e0c8; }
      [data-bs-theme="dark"] .form-control:focus { background: #162018; }
      [data-bs-theme="dark"] .btn-outline-secondary { border-color: #2a4030; color: #8ab08a; }
      [data-bs-theme="dark"] .btn-outline-secondary:hover { background: #253b2a; color: #c8e0c8; }
      [data-bs-theme="dark"] .btn-outline-primary { color: #86c99a; border-color: #3d7a55; }
      [data-bs-theme="dark"] .btn-outline-primary:hover { background: #3d7a55; color: #fff; }
      [data-bs-theme="dark"] hr { border-color: #253b2a; }
      [data-bs-theme="dark"] .modal-content { background: #162018 !important; border-color: #253b2a !important; }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark" style="background: var(--wnw-dark); border-bottom: 2px solid #2d5a3d;">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand" do %>
          <span class="wnw-logo wnw-logo-sm"></span>
          <span class="brand-text">World <span>Nomad</span> Web</span>
        <% end %>
        <div class="d-flex align-items-center gap-2">
          <%= link_to "Stories", frontoffice_travel_stories_path,
                class: "btn btn-sm btn-outline-light" %>
          <% if current_user %>
            <%= link_to "My Dashboard", backoffice_root_path, class: "btn btn-sm btn-outline-light" %>
          <% else %>
            <%= link_to "Join", backoffice_register_path, class: "btn btn-sm btn-outline-light" %>
            <%= link_to "Sign in", backoffice_login_path, class: "btn btn-sm btn-primary" %>
          <% end %>
          <button onclick="toggleTheme()" id="fo-theme-toggle"
                  class="btn btn-sm btn-outline-light"
                  style="width:34px;height:34px;padding:0;display:flex;align-items:center;justify-content:center;"
                  title="Toggle dark mode">
            <i class="bi" id="fo-theme-icon"></i>
          </button>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="alert alert-success alert-dismissible fade show rounded-0 mb-0 text-center py-2">
        <%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-danger alert-dismissible fade show rounded-0 mb-0 text-center py-2">
        <%= alert %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <%= yield %>

    <footer class="py-5 mt-5">
      <div class="container text-center text-secondary">
        <span class="wnw-logo wnw-logo-lg d-block mx-auto mb-3"></span>
        <p class="mb-1 text-light fw-semibold fs-5">World Nomad Web</p>
        <small>Connecting talent from every corner of the world</small>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      function applyThemeIcon(t) {
        const icon = document.getElementById("fo-theme-icon");
        if (icon) icon.className = "bi bi-" + (t === "dark" ? "sun-fill" : "moon-fill");
      }
      function toggleTheme() {
        const cur  = document.documentElement.getAttribute("data-bs-theme");
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-bs-theme", next);
        localStorage.setItem("wnw-theme", next);
        applyThemeIcon(next);
      }
      applyThemeIcon(document.documentElement.getAttribute("data-bs-theme"));
    </script>
  </body>
</html>
