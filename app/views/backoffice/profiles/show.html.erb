<% content_for :page_title, "My Profile" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0">My Profile</h4>
  <%= link_to edit_backoffice_profile_path, class: "btn btn-primary" do %>
    <i class="bi bi-pencil-square me-1"></i>Edit Profile
  <% end %>
</div>

<div class="row g-4">
  <div class="col-md-4">
    <div class="card p-4 text-center">
      <img src="<%= user_avatar_url(current_user, 150) %>" alt="avatar"
           class="rounded-circle mx-auto mb-3" style="width:110px;height:110px;object-fit:cover;border:3px solid var(--wnw-border,#c4d4b8);">
      <h5 class="fw-bold mb-1"><%= current_user.name %></h5>
      <p class="text-muted mb-2"><%= current_user.profession %></p>
      <span class="badge fs-6 <%= current_user.published? ? 'bg-success' : 'bg-warning text-dark' %>">
        <i class="bi bi-<%= current_user.published? ? 'check-circle' : 'eye-slash' %> me-1"></i>
        <%= current_user.published? ? "Listed in directory" : "Hidden from directory" %>
      </span>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card p-4">
      <dl class="row mb-0">
        <dt class="col-sm-4 text-muted">Country</dt>
        <dd class="col-sm-8"><%= current_user.country %></dd>

        <dt class="col-sm-4 text-muted">Email</dt>
        <dd class="col-sm-8"><%= current_user.email %></dd>

        <dt class="col-sm-4 text-muted">WhatsApp</dt>
        <dd class="col-sm-8">
          <% if current_user.whatsapp.present? %>
            <%= link_to current_user.whatsapp, current_user.whatsapp_url, target: "_blank", class: "text-success" %>
          <% else %>
            <span class="text-muted">Not specified</span>
          <% end %>
        </dd>

        <dt class="col-sm-4 text-muted">Bio</dt>
        <dd class="col-sm-8">
          <% if current_user.bio.present? %>
            <%= simple_format(current_user.bio, class: "mb-0") %>
          <% else %>
            <span class="text-muted">No description yet.</span>
          <% end %>
        </dd>
      </dl>
    </div>

    <div class="d-flex gap-2 mt-3">
      <% if current_user.published? %>
        <%= link_to frontoffice_profile_path(current_user), class: "btn btn-outline-primary", target: "_blank" do %>
          <i class="bi bi-box-arrow-up-right me-1"></i>View public profile
        <% end %>
      <% end %>
      <%= link_to edit_backoffice_profile_path, class: "btn btn-primary" do %>
        <i class="bi bi-pencil-square me-1"></i>Edit
      <% end %>
    </div>
  </div>
</div>
