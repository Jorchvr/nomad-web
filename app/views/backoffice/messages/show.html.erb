<% content_for :page_title, "Chat with #{@other.name}" %>

<div class="d-flex align-items-center gap-3 mb-3">
  <%= link_to backoffice_messages_path,
        class: "text-decoration-none text-muted d-inline-flex align-items-center gap-1" do %>
    <i class="bi bi-arrow-left"></i>
  <% end %>
  <img src="<%= user_avatar_url(@other, 40) %>"
       alt="<%= @other.name %>"
       class="rounded-circle"
       style="width:40px;height:40px;object-fit:cover;border:2px solid var(--wnw-border);">
  <div>
    <p class="mb-0 fw-semibold" style="font-family:'Lora',serif;"><%= @other.name %></p>
    <p class="mb-0 text-muted small"><%= @other.profession %> · <%= @other.country %></p>
  </div>
  <%= link_to backoffice_member_path(@other), class: "btn btn-sm btn-outline-secondary ms-auto" do %>
    <i class="bi bi-person me-1"></i>Profile
  <% end %>
</div>

<!-- Chat window -->
<div class="card p-0 overflow-hidden" style="display:flex;flex-direction:column;">

  <div id="chat-messages"
       style="height:62vh;overflow-y:auto;padding:1.25rem;display:flex;flex-direction:column;gap:.75rem;background:var(--chat-bg, #f8fbf8);">

    <% if @messages.empty? %>
      <div class="text-center text-muted my-auto" style="padding:3rem 0;">
        <i class="bi bi-chat-heart fs-1 mb-3 d-block" style="color:#c4d4b8;"></i>
        Start a conversation with <%= @other.name %>!
      </div>
    <% end %>

    <% prev_date = nil %>
    <% @messages.each do |msg| %>
      <% msg_date = msg.created_at.to_date %>
      <% if msg_date != prev_date %>
        <div class="text-center my-1">
          <span class="badge rounded-pill" style="background:rgba(0,0,0,.07);color:#6a8a6a;font-size:.72rem;font-weight:500;">
            <%= msg_date == Date.today ? "Today" : msg_date == Date.yesterday ? "Yesterday" : msg_date.strftime("%B %-d") %>
          </span>
        </div>
        <% prev_date = msg_date %>
      <% end %>

      <% is_mine = msg.sender_id == current_user.id %>
      <div class="d-flex align-items-end gap-2 <%= is_mine ? 'flex-row-reverse' : '' %>">
        <img src="<%= user_avatar_url(is_mine ? current_user : @other, 32) %>"
             class="rounded-circle flex-shrink-0"
             style="width:28px;height:28px;object-fit:cover;border:1.5px solid var(--wnw-border);"
             alt="">
        <div style="max-width:68%;">
          <div class="px-3 py-2 rounded-4"
               style="<%= is_mine ? 'background:#3d7a55;color:#fff;border-bottom-right-radius:6px!important;' : 'background:var(--bubble-other, #fff);border:1.5px solid var(--wnw-border);border-bottom-left-radius:6px!important;' %>
                      word-break:break-word;line-height:1.45;font-size:.9rem;">
            <%= simple_format(msg.body) %>
          </div>
          <p class="mb-0 mt-1 text-muted <%= is_mine ? 'text-end' : '' %>" style="font-size:.7rem;">
            <%= msg.created_at.strftime("%-I:%M %p") %>
          </p>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Input bar -->
  <div style="border-top:1.5px solid var(--wnw-border);padding:1rem;background:var(--input-bar-bg, #fff);">
    <%= form_with url: backoffice_messages_path, method: :post,
          data: { turbo: false },
          class: "d-flex gap-2 align-items-end" do |f| %>
      <%= f.hidden_field :message, name: "message[receiver_id]", value: @other.id %>
      <div class="flex-grow-1">
        <%= f.text_area :body, name: "message[body]",
              class: "form-control rounded-3",
              placeholder: "Write a message...",
              rows: 1,
              style: "resize:none;max-height:120px;overflow-y:auto;",
              id: "msg-input",
              required: true %>
      </div>
      <button type="submit" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
              style="width:44px;height:44px;padding:0;">
        <i class="bi bi-send-fill"></i>
      </button>
    <% end %>
  </div>
</div>

<script>
  // Scroll to bottom
  const chatEl = document.getElementById("chat-messages");
  chatEl.scrollTop = chatEl.scrollHeight;

  // Auto-grow textarea
  const input = document.getElementById("msg-input");
  input.addEventListener("input", function () {
    this.style.height = "auto";
    this.style.height = Math.min(this.scrollHeight, 120) + "px";
  });

  // Send on Enter (Shift+Enter = newline)
  input.addEventListener("keydown", function (e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      this.closest("form").submit();
    }
  });

  // Dark mode bubble colors
  if (document.documentElement.getAttribute("data-bs-theme") === "dark") {
    document.getElementById("chat-messages").style.setProperty("--chat-bg", "#111c14");
    document.querySelectorAll(".input-bar-bg").forEach(el => el.style.background = "#162018");
  }
</script>

<style>
  [data-bs-theme="dark"] #chat-messages { background: #111c14 !important; }
  [data-bs-theme="dark"] .rounded-4:not([style*="background:#3d7a55"]) {
    background: #1e2e20 !important;
    border-color: #2a4030 !important;
  }
  [data-bs-theme="dark"] [style*="background:var(--input-bar-bg"],
  [data-bs-theme="dark"] [style*="background:var(--bubble-other"] {
    background: #162018 !important;
  }
</style>
