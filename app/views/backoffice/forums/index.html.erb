<% content_for :page_title, "Forums" %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <h4 class="fw-bold mb-0"><i class="bi bi-chat-square-text-fill me-2 text-primary"></i>Forums</h4>
  <%= link_to new_backoffice_forum_path, class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-plus-lg me-1"></i>New forum
  <% end %>
</div>

<% if @forums.any? %>
  <div class="card">
    <% @forums.each_with_index do |forum, i| %>
      <div class="p-4 <%= i < @forums.count - 1 ? 'border-bottom' : '' %>">
        <div class="d-flex gap-3">
          <img src="<%= user_avatar_url(forum.user, 48) %>" class="rounded-circle flex-shrink-0"
               width="48" height="48">
          <div class="flex-grow-1 min-w-0">
            <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
              <%= link_to forum.title, backoffice_forum_path(forum),
                    class: "fw-semibold text-decoration-none text-dark fs-6 lh-sm" %>
              <span class="badge bg-light text-muted flex-shrink-0">
                <i class="bi bi-chat me-1"></i><%= forum.forum_posts.count %>
              </span>
            </div>
            <% if forum.body.present? %>
              <p class="text-muted small mb-2 lh-sm"><%= truncate(forum.body, length: 180) %></p>
            <% end %>
            <div class="text-muted" style="font-size:.78rem;">
              <%= link_to forum.user.name, backoffice_member_path(forum.user),
                    class: "text-decoration-none text-muted fw-semibold" %>
              &nbsp;·&nbsp;<%= time_ago_in_words(forum.created_at) %> ago
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card p-5 text-center text-muted">
    <i class="bi bi-chat-square-text fs-1 d-block mb-3 opacity-25"></i>
    <p class="mb-2">No forums yet.</p>
    <%= link_to "Create the first one", new_backoffice_forum_path, class: "btn btn-primary btn-sm" %>
  </div>
<% end %>
