<% content_for :page_title, "My Travel Stories" %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h4 class="fw-bold mb-0" style="font-family:'Lora',serif;color:#1a2e20;">
      <i class="bi bi-map me-2" style="color:#3d7a55;"></i>My Travel Stories
    </h4>
    <p class="text-muted small mb-0 mt-1">Share your nomad experiences with clients around the world</p>
  </div>
  <%= link_to new_backoffice_travel_story_path,
        class: "btn btn-primary d-flex align-items-center gap-2" do %>
    <i class="bi bi-plus-lg"></i> New Story
  <% end %>
</div>

<% if @stories.empty? %>
  <div class="card p-5 text-center">
    <i class="bi bi-map fs-1 mb-3 d-block" style="color:#c4d4b8;"></i>
    <h5 class="fw-semibold mb-2" style="color:#2d6044;">No stories yet</h5>
    <p class="text-muted mb-4">Share your first nomad experience — where you worked, the client, the adventure.</p>
    <%= link_to "Write your first story", new_backoffice_travel_story_path, class: "btn btn-primary" %>
  </div>
<% else %>
  <div class="row g-3">
    <% @stories.each do |story| %>
      <div class="col-12">
        <div class="card p-0 overflow-hidden">
          <div class="row g-0">
            <!-- Cover photo -->
            <div class="col-md-3" style="min-height:160px;background:#e8f0e2;">
              <% if story.photos.attached? %>
                <%= image_tag story.photos.first,
                      style: "width:100%;height:100%;object-fit:cover;min-height:160px;",
                      alt: "" %>
              <% else %>
                <div class="d-flex align-items-center justify-content-center h-100" style="min-height:160px;">
                  <i class="bi bi-image fs-1" style="color:#c4d4b8;"></i>
                </div>
              <% end %>
            </div>
            <!-- Info -->
            <div class="col-md-9 p-4 d-flex flex-column justify-content-between">
              <div>
                <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                  <h5 class="fw-semibold mb-0" style="font-family:'Lora',serif;color:#1a2e20;">
                    <%= story.title %>
                  </h5>
                  <% if story.published? %>
                    <span class="badge badge-published flex-shrink-0">Published</span>
                  <% else %>
                    <span class="badge badge-draft flex-shrink-0">Draft</span>
                  <% end %>
                </div>
                <div class="d-flex flex-wrap gap-3 text-muted small mb-2">
                  <span><i class="bi bi-geo-alt me-1" style="color:#3d7a55;"></i><%= story.location %></span>
                  <% if story.client_name.present? %>
                    <span><i class="bi bi-briefcase me-1" style="color:#3d7a55;"></i><%= story.client_name %></span>
                  <% end %>
                  <span><i class="bi bi-calendar3 me-1" style="color:#3d7a55;"></i><%= story.visited_at.strftime("%B %Y") %></span>
                  <span><i class="bi bi-images me-1" style="color:#3d7a55;"></i><%= story.photos.size %> photos</span>
                </div>
                <p class="text-muted small mb-0" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                  <%= story.description %>
                </p>
              </div>
              <div class="d-flex gap-2 mt-3">
                <%= link_to edit_backoffice_travel_story_path(story),
                      class: "btn btn-sm btn-outline-primary" do %>
                  <i class="bi bi-pencil me-1"></i>Edit
                <% end %>
                <%= button_to backoffice_travel_story_path(story), method: :delete,
                      class: "btn btn-sm btn-outline-danger",
                      form: { data: { turbo_confirm: "Delete this story?" } } do %>
                  <i class="bi bi-trash me-1"></i>Delete
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
